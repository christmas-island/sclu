# SCLU Bot — Environment Variables
# Copy to .env and fill in your values

# Discord bot token (required)
# Get one at https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Auto-scan channels (optional)
# Comma-separated channel IDs or names — bot will auto-scan any image posted here
# Leave blank to require explicit !sclu command
AUTOSCAN_CHANNELS=

# Logging level (optional, default: INFO)
LOG_LEVEL=INFO
